# =============================================================================
# 🔌 Tecda Maniquí - Suite de Pruebas v2.1.0
# =============================================================================
@baseUrl = http://localhost:8081
@contentType = application/json
@token = {{login.response.body.token}}

### 1. Login (Gerente)
# @name login
POST {{baseUrl}}/auth/login
Content-Type: {{contentType}}

{
  "username": "admin_pablo",
  "password": "tecda2026"
}

### 2. Registrar Maniquí (Vía SP EnsamblarManiqui)
# Valida que el SP asigne automáticamente 6 piezas del modelo 1
POST {{baseUrl}}/maniquies
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "modelo_id": 1,
  "numero_serie": "SQL-SP-ENSAMBLE-01"
}

### 3. Listar Clientes Activos (Soft Delete)
GET {{baseUrl}}/clientes?activo=true
Authorization: Bearer {{token}}

### 4. Registrar Venta con Facturación (Step 5)
POST {{baseUrl}}/ventas
Authorization: Bearer {{token}}
Content-Type: {{contentType}}

{
  "cliente_id": 1,
  "metodo_pago": "Transferencia",
  "maniquies": [
    { "maniqui_id": 1, "precio_final": 15000.00 }
  ]
}

### 5. Dashboard de Rentabilidad (Vistas SQL)
GET {{baseUrl}}/reportes/rentabilidad
Authorization: Bearer {{token}}
