# Puerto de escucha del servidor Express (Backend)
PORT=8082

# Secreto para la firma y verificación de JSON Web Tokens (JWT)
JWT_SECRET=reemplazar_con_un_secreto_seguro

# Nombre de la base de datos MySQL/MariaDB
DB_NAME=tecda_maniqui

# Usuario de conexión a la base de datos
DB_USER=root

# Contraseña de conexión a la base de datos
DB_PASS=password

# Host de la base de datos (Docker compose mapea a localhost)
DB_HOST=127.0.0.1

# Puerto mapeado de la base de datos (Docker expone a 3307)
DB_PORT=3307
