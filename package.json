{
  "name": "tp-maniqui-backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=11.2.2"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "mock": "npx @stoplight/prism-cli mock openapi.yaml -p 8083 -d",
    "preinstall": "npx only-allow pnpm",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "node --test --import tsx tests/unit/*.test.ts",
    "test:integration": "bash tests/integration/test_all.sh",
    "doc:api": "npx @redocly/cli build-docs openapi.yaml -o docs/api/redoc.html",
    "doc:ts": "typedoc",
    "doc": "npm run doc:api && npm run doc:ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.3.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "mysql2": "^3.22.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "sequelize": "^6.37.8",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@redocly/cli": "^2.31.4",
    "@stoplight/prism-cli": "^5.15.10",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.9.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/validator": "^13.15.10",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdoc": "^4.0.4",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  }
}
